@page "/addtodo"
@page "/edittodo/{id:int}"
@using nima.Data
@inject TodoStorage Storage
@inject NavigationManager Nav

<div class="form-container">
    <h2>@(IsEdit ? "✏️ ویرایش کار" : "➕ کار جدید")</h2>

    <div class="form-group">
        <label>عنوان *</label>
        <input type="text" class="form-control" @bind="todo.Title" />
    </div>

    <div class="form-group">
        <label>توضیحات</label>
        <textarea class="form-control" rows="3" @bind="todo.Description"></textarea>
    </div>

    <div class="form-row">
        <div class="form-group half">
            <label>تاریخ سررسید</label>
            <input type="date" class="form-control" @bind="todo.DueDate" @bind:format="yyyy-MM-dd" />
        </div>
        <div class="form-group half">
            <label>ساعت سررسید</label>
            <input type="time" class="form-control" value="@TimeString" @onchange="OnTimeChanged" />
        </div>
    </div>

    <div class="form-group">
        <label>اولویت</label>
        <select class="form-select" @bind="todo.Priority">
            <option value="1">🟢 کم</option>
            <option value="2">🟡 متوسط</option>
            <option value="3">🔴 بالا</option>
        </select>
    </div>

    <div class="form-group">
        <label>دسته‌بندی</label>
        <select class="form-select" @bind="todo.Category">
            <option value="work">💼 کاری</option>
            <option value="personal">👤 شخصی</option>
            <option value="shopping">🛒 خرید</option>
            <option value="health">🏃 سلامتی</option>
            <option value="other">📌 سایر</option>
        </select>
    </div>

    <div class="button-group">
        <button class="btn btn-primary" @onclick="Save">💾 ذخیره</button>
        <button class="btn btn-secondary" @onclick="Cancel">🔙 انصراف</button>
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }
    private TodoItem todo = new();
    private bool IsEdit => Id != 0;
    private string TimeString { get; set; } = "09:00";

    protected override void OnInitialized()
    {
        if (IsEdit)
        {
            var todos = Storage.LoadTodos();
            todo = todos.FirstOrDefault(t => t.Id == Id) ?? new TodoItem();
            // تنظیم زمان برای نمایش در input
            TimeString = todo.DueTime.ToString(@"hh\:mm");
        }
        else
        {
            todo = new TodoItem
                {
                    Id = Storage.GetNextId(),
                    DueDate = DateTime.Now.AddDays(1),
                    DueTime = new TimeSpan(9, 0, 0),
                    Priority = 2,
                    Category = "personal",
                    CreatedAt = DateTime.Now
                };
            TimeString = "09:00";
        }
    }

    private void OnTimeChanged(ChangeEventArgs e)
    {
        var timeValue = e.Value?.ToString();
        if (!string.IsNullOrEmpty(timeValue))
        {
            var parts = timeValue.Split(':');
            if (parts.Length == 2)
            {
                var hours = int.Parse(parts[0]);
                var minutes = int.Parse(parts[1]);
                todo.DueTime = new TimeSpan(hours, minutes, 0);
                TimeString = timeValue;
            }
        }
    }

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(todo.Title))
        {
            App.Current.MainPage.DisplayAlert("خطا", "عنوان الزامی است", "باشه");
            return;
        }

        var todos = Storage.LoadTodos();
        if (IsEdit)
        {
            var index = todos.FindIndex(t => t.Id == todo.Id);
            if (index != -1) todos[index] = todo;
        }
        else
        {
            todos.Add(todo);
        }
        Storage.SaveTodos(todos);
        Nav.NavigateTo("/todos");
    }

    private void Cancel()
    {
        Nav.NavigateTo("/todos");
    }
}